extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    +alertSuccess(300)
    +alertError(300)
    .container.mt-4
        .card.product-card
            .card-body
                h2.card-title.text-center.mb-4 Chi tiết sản phẩm

                if (product.title)
                    h3.text-primary.mb-3 #{product.title}

                if (product.thumbnail)
                    .text-center.mb-3
                        img.product-image(src=product.thumbnail)

                .row
                    .col-md-6
                        if (product.price)
                            p.info-item
                                span.label Giá:
                                b.text-danger #{product.price}$

                        if (product.discountPercentage)
                            p.info-item
                                span.label Giảm giá:
                                b.text-success #{product.discountPercentage}%

                        if (product.stock)
                            p.info-item
                                span.label Còn lại:
                                b #{product.stock}

                    .col-md-6
                        if (product.status)
                            p.info-item
                                span.label Trạng thái:
                                if (product.status === "active")
                                    span.badge.badge-success Hoạt động
                                else
                                    span.badge.badge-danger Dừng hoạt động

                        if (product.position)
                            p.info-item
                                span.label Vị trí:
                                b #{product.position}

                if (product.description)
                    hr
                    .description
                        h5 Mô tả sản phẩm
                        .content !{product.description}

                .text-end.mt-4
                    a.btn.btn-warning(href=`${prefixAdmin}/products/edit/${product.id}`) Sửa

        // ===== COMMENTS =====
        .card.mt-4
            .card-body
                h4.mb-3 Bình luận

                if (comments && comments.length > 0)
                    each comment in comments
                        .comment-item
                            .d-flex.justify-content-between
                                div
                                    b #{comment.user_id.fullName || "Người dùng"}
                                    if (comment.rating)
                                        span.text-warning.ml-2 ⭐ #{comment.rating}/5

                                form(
                                    action=`${prefixAdmin}/comments/delete/${comment._id}?_method=DELETE` 
                                    method="POST"
                                    onsubmit="return confirm('Xóa bình luận này?')"
                                )
                                    button.btn.btn-danger.btn-sm Xóa

                            if (comment.content)
                                p.mt-2.mb-1 #{comment.content}

                            if (comment.image)
                                img.comment-image(src=comment.image)

                            hr
                else
                    p.text-muted Chưa có bình luận nào

    script(src="/admin/js/product.js")